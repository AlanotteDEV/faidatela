rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ============================================================
       FUNZIONI DI UTILITÀ
       ============================================================ */

    // Admin autorizzati (lettura + eliminazione ordini).
    // ⚠️ Per aggiungere un secondo admin, decommenta la riga e
    //    metti l'email REALE (identica a quella creata in
    //    Authentication → Users), poi ripubblica le regole.
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          "alanotte6@gmail.com","aledesalvia13@gmail.com"
          // , "seconda-email-admin@esempio.com"
        ];
    }

    // Stringa obbligatoria: presente, non vuota, entro il limite.
    function isValidString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    // Stringa facoltativa: può mancare o essere null; se c'è, valida.
    function optionalString(data, key, maxLen) {
      return !(key in data) || data[key] == null ||
        (data[key] is string && data[key].size() <= maxLen);
    }

    /* ============================================================
       COLLEZIONE ORDINI
       ============================================================ */
    match /ordini/{ordineId} {

      // CREATE — Form pubblico, nessun login richiesto.
      allow create: if
        // Campi obbligatori
        isValidString(request.resource.data.nome, 100) &&
        isValidString(request.resource.data.carta, 200) &&
        isValidString(request.resource.data.espansione, 200) &&

        // Campi facoltativi
        optionalString(request.resource.data, 'cognome', 100) &&
        optionalString(request.resource.data, 'ig', 100) &&
        optionalString(request.resource.data, 'note', 1000) &&

        // Immagine: solo veri data-URL immagine, sotto il limite documento (1MB).
        // base64 di un file ~500KB ≈ 683.000 caratteri: 720.000 lascia margine.
        (
          request.resource.data.img == null ||
          (
            request.resource.data.img is string &&
            request.resource.data.img.size() <= 720000 &&
            request.resource.data.img.matches('data:image/(png|jpe?g|webp|gif);base64,[A-Za-z0-9+/=]+')
          )
        ) &&

        // Timestamp generato dal server: non falsificabile dal client.
        request.resource.data.createdAt == request.time &&

        // Nessun campo extra + presenza dei campi attesi.
        request.resource.data.keys().hasOnly(['nome','cognome','ig','carta','espansione','note','img','createdAt']) &&
        request.resource.data.keys().hasAll(['nome','carta','espansione','img','createdAt']);

      // READ & DELETE — Solo gli admin autorizzati.
      allow read, delete: if isAdmin();

      // UPDATE — Sempre bloccato (gli ordini sono immutabili).
      allow update: if false;
    }

    /* ============================================================
       DEFAULT DENY — Qualsiasi altro percorso è negato.
       ============================================================ */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
